# SynapseERP — Docker environment variables template
#
# Copy this file to .env.docker and fill in the required values before running.
# Usage: docker compose --env-file .env.docker up -d --build
# Or:    ./synapse docker:up   (reads .env.docker by default)
#
# WARNING: Do NOT commit .env.docker to version control — it contains secrets.
# .env.docker is listed in .gitignore.

# ============================================================
# REQUIRED — must be set before running
# ============================================================

# Django secret key: any long random string.
# Generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-this-to-a-long-random-string

# PostgreSQL superuser password for the synapse_user account.
DB_PASSWORD=change-this-to-a-strong-password

# ============================================================
# OPTIONAL — defaults shown below are safe for a local install
# ============================================================

# PostgreSQL database and user names
DB_NAME=synapse_db
DB_USER=synapse_user

# Django settings
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost

# Nginx public port (default 80; change to e.g. 8080 if port 80 is taken)
NGINX_PORT=80

# Gunicorn worker count (rule of thumb: 2 × CPU cores + 1)
GUNICORN_WORKERS=3

# ============================================================
# OPTIONAL — Obsidian vault sync
# ============================================================
# To enable Obsidian ↔ DB sync inside Docker, set OBSIDIAN_VAULT_PATH
# to the absolute path of your vault on the HOST machine.
# That's it — the directory is automatically bind-mounted read-only into
# the container at /vault, and the backend is configured to use /vault.
# No edits to docker-compose.yml are needed.
#
# After setting this value, restart the stack:
#   ./synapse docker:down && ./synapse docker:up
#
# OBSIDIAN_VAULT_PATH=/home/youruser/Documents/MyVault
