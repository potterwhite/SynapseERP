fn_completion() {
    local shell="${1:-}"

    # Auto-detect shell if not specified
    if [ -z "$shell" ]; then
        if [ -n "$ZSH_VERSION" ]; then
            shell="zsh"
        else
            shell="bash"
        fi
    fi

    case "$shell" in
        bash)
            fn_log "# ── Bash completion for ./synapse ──────────────────────────────" "blue"
            fn_log "# To enable permanently, add this line to ~/.bashrc:" "yellow"
            fn_log "#   eval \"\$($(pwd)/synapse completion bash)\"" "yellow"
            fn_log "# Or source a saved file:" "yellow"
            fn_log "#   ./synapse completion bash > ~/.synapse_completion.sh" "yellow"
            fn_log "#   echo 'source ~/.synapse_completion.sh' >> ~/.bashrc" "yellow"
            echo ""
            fn_print_bash_completion
            ;;
        zsh)
            fn_log "# ── Zsh completion for ./synapse ───────────────────────────────" "blue"
            fn_log "# To enable permanently, add this line to ~/.zshrc:" "yellow"
            fn_log "#   eval \"\$($(pwd)/synapse completion zsh)\"" "yellow"
            fn_log "# Or source a saved file:" "yellow"
            fn_log "#   ./synapse completion zsh > ~/.synapse_completion.zsh" "yellow"
            fn_log "#   echo 'source ~/.synapse_completion.zsh' >> ~/.zshrc" "yellow"
            echo ""
            fn_print_zsh_completion
            ;;
        *)
            fn_log "❌ Unknown shell: '$shell'. Supported: bash | zsh" "red"
            exit 1
            ;;
    esac
}

# --- Main Dispatcher ---

main() {
    local command="${1:-help}"

    case "$command" in
        # Commands that do NOT need the venv to already exist
        prepare)        fn_prepare_env ;;
        clean)          fn_clean ;;
        frontend:init)  fn_frontend_init ;;
        completion)     fn_completion "$2" ;;
        help|--help|-h) fn_show_help ;;

        # All other commands need the venv active
        *)
            fn_activate_venv
            case "$command" in
                run)                    fn_run_backend ;;
                frontend:run)           fn_run_frontend ;;
                run:all)                fn_run_all ;;
                vault:watch)            fn_vault_watch "$2" ;;
                frontend:build)         fn_frontend_build ;;
                docker:build)           fn_docker_build "$2" ;;
                docker:up)              fn_docker_up "$2" ;;
                docker:down)            fn_docker_down "$2" ;;
                docker:clean)           fn_docker_clean "$2" ;;
                docker:logs)            fn_docker_logs "$2" ;;
                docker:shell)           fn_docker_shell "$2" ;;
                docker:manage)          fn_docker_manage "${@:2}" ;;
                deploy)                 fn_deploy ;;
                superuser)              fn_create_superuser ;;
                set-rule)               fn_set_rule_url "$2" ;;
                dev:migrate)            fn_dev_migrate ;;
                dev:test)               fn_dev_test ;;
                dev:makemessages)       fn_dev_makemessages ;;
                dev:compilemessages)    fn_dev_compilemessages ;;
                *)
                    fn_log "❌ Unknown command: '$command'" "red"
                    fn_show_help
                    exit 1
                    ;;
            esac
            ;;
    esac
}

main "$@"
