    echo "Usage: ./synapse <command>"
    echo ""
    echo "━━━ Setup ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  prepare             One-time setup: create .venv, install deps, migrate DB"
    echo "  clean               Destructive reset: remove .venv, DB, node_modules, dist"
    echo ""
    echo "━━━ Running ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  run                 Start Django backend dev server (port 8000)"
