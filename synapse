fn_print_bash_completion() {
    cat <<'BASH_COMPLETION'
# bash completion for ./synapse
# Source this file or add the eval line to your ~/.bashrc
_synapse_completions() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local commands="prepare clean run frontend:run run:all vault:watch frontend:init frontend:build superuser set-rule completion dev:migrate dev:test dev:makemessages dev:compilemessages docker:build docker:up docker:down docker:clean docker:logs docker:shell docker:manage deploy help"
    COMPREPLY=($(compgen -W "${commands}" -- "${cur}"))
}
complete -F _synapse_completions synapse
complete -F _synapse_completions ./synapse
BASH_COMPLETION
}

